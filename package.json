{
  "name": "viability-torus-lab",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "tsx --test tests/api.test.mjs tests/contracts.test.mjs tests/dynamic-modules.test.mjs tests/empirical.test.mjs tests/registry.test.mjs tests/mcp.test.mjs tests/simulator.test.mjs tests/visualizations.test.mjs tests/watchlist.test.mjs",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "schemas:generate": "tsx scripts/generate-schemas.ts",
    "vtl": "tsx scripts/vtl.ts",
    "experiment": "tsx scripts/vtl.ts simulate",
    "empirical:analyze": "tsx scripts/vtl.ts empirical-analyze",
    "empirical:aggregate": "tsx scripts/vtl.ts empirical-aggregate",
    "sweep": "tsx scripts/vtl.ts sweep",
    "proposal:validate": "tsx scripts/vtl.ts validate-proposal",
    "mcp": "tsx scripts/mcp-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "type": "module"
}
