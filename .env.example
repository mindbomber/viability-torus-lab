# Browser-local Empirical Lab needs no server configuration.

# Local stdio MCP file access. Use the platform path delimiter for multiple roots.
VTL_EMPIRICAL_ROOTS=

# Remote empirical API and MCP tools are disabled unless explicitly enabled.
VTL_ENABLE_EMPIRICAL_API=false
VTL_EMPIRICAL_API_TOKEN=
VTL_EMPIRICAL_API_ORIGIN=

# Keep false unless the self-hosted operator has appropriate authorization,
# transport, upstream logging, retention, and governance controls.
VTL_ALLOW_SENSITIVE_EMPIRICAL_DATA=false
