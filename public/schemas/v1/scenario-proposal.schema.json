{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "default": "1.0.0",
      "type": "string",
      "const": "1.0.0"
    },
    "status": {
      "type": "string",
      "const": "draft"
    },
    "action": {
      "type": "string",
      "enum": [
        "create",
        "revise"
      ]
    },
    "proposedBy": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "agent",
            "human"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "additionalProperties": false
    },
    "rationale": {
      "type": "string",
      "minLength": 30,
      "maxLength": 5000
    },
    "scenario": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "title": {
          "type": "string",
          "minLength": 4,
          "maxLength": 160
        },
        "shortTitle": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "summary": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        },
        "category": {
          "type": "string",
          "enum": [
            "AI",
            "Organizations",
            "Healthcare",
            "Ecology"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "Introductory",
            "Intermediate",
            "Advanced"
          ]
        },
        "icon": {
          "type": "string",
          "minLength": 1,
          "maxLength": 12
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "optimizedOutcome": {
          "type": "string",
          "minLength": 5,
          "maxLength": 300
        },
        "viableRegion": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "hiddenConstraint": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "debtMechanism": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "irreversibleMechanism": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "interventionIds": {
          "minItems": 1,
          "maxItems": 30,
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "warningConditions": {
          "minItems": 1,
          "maxItems": 20,
          "type": "array",
